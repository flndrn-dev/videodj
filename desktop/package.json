{
  "name": "djstudio-desktop",
  "version": "1.0.0",
  "description": "videoDJ.Studio — AI-powered Video DJ Desktop App",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "dist:mac": "vite build && electron-builder --mac",
    "dist:win": "vite build && electron-builder --win",
    "dist:linux": "vite build && electron-builder --linux"
  },
  "build": {
    "appId": "studio.videodj.app",
    "productName": "videoDJ.Studio",
    "copyright": "Copyright © 2026 mavi",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "src/main/**/*", "src/preload/**/*", "tools/**/*", "package.json"],
    "mac": {
      "category": "public.app-category.music",
      "target": [{ "target": "dmg", "arch": ["x64", "arm64"] }]
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "linux": {
      "category": "AudioVideo",
      "target": ["AppImage", "deb"]
    }
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "music-metadata": "^10.5.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.163.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
